<!DOCTYPE index>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cuchara Ergonomica para Zurdos</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Geist+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --plum: #2D0A4E;
    --violet: #6B21A8;
    --lavender: #C084FC;
    --pale: #F5F0FF;
    --silver: #C8C8C8;
    --silver-light: #E8E8E8;
    --white: #FAFAFA;
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--plum);
    color: var(--pale);
    font-family: 'Cormorant Garamond', Georgia, serif;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1000;
    opacity: 0.6;
  }

  nav {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 4rem;
    border-bottom: 1px solid rgba(192, 132, 252, 0.15);
    backdrop-filter: blur(12px);
    background: rgba(45, 10, 78, 0.7);
  }

  .nav-logo {
    font-family: 'Geist Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: var(--lavender);
    text-transform: uppercase;
  }

  .nav-cta {
    font-family: 'Geist Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--plum);
    background: var(--lavender);
    border: none;
    padding: 0.6rem 1.4rem;
    cursor: pointer;
    transition: background 0.2s;
  }
  .nav-cta:hover { background: var(--pale); }

  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    overflow: hidden;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 10rem 4rem 6rem 4rem;
    position: relative;
    z-index: 2;
  }

  .hero-tag {
    font-family: 'Geist Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.35em;
    color: var(--lavender);
    text-transform: uppercase;
    margin-bottom: 2.5rem;
    opacity: 0;
    animation: fadeUp 0.8s 0.2s forwards;
  }

  .hero-h1 {
    font-size: clamp(3.5rem, 6vw, 7rem);
    font-weight: 300;
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.9s 0.4s forwards;
  }

  .hero-h1 em { font-style: italic; color: var(--lavender); }

  .hero-sub {
    font-size: 1.25rem;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(245, 240, 255, 0.7);
    max-width: 38ch;
    margin-bottom: 3.5rem;
    opacity: 0;
    animation: fadeUp 0.9s 0.6s forwards;
  }

  .hero-actions {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    opacity: 0;
    animation: fadeUp 0.9s 0.8s forwards;
  }

  .btn-primary {
    background: var(--lavender);
    color: var(--plum);
    border: none;
    padding: 1rem 2.4rem;
    font-family: 'Geist Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.25s;
  }
  .btn-primary:hover { background: var(--pale); transform: translateY(-2px); }

  .btn-ghost {
    background: transparent;
    color: var(--lavender);
    border: 1px solid rgba(192, 132, 252, 0.4);
    padding: 1rem 2.4rem;
    font-family: 'Geist Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.25s;
    text-decoration: none;
    display: inline-block;
  }
  .btn-ghost:hover { border-color: var(--lavender); background: rgba(192, 132, 252, 0.08); }

  .hero-right {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-right::before {
    content: '';
    position: absolute;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(107, 33, 168, 0.5) 0%, transparent 70%);
    border-radius: 50%;
    animation: pulse 4s ease-in-out infinite;
  }

  .hero-img {
    width: 90%;
    max-width: 580px;
    position: relative;
    z-index: 2;
    filter: drop-shadow(0 30px 80px rgba(107, 33, 168, 0.6));
    animation: floatSpoon 6s ease-in-out infinite, fadeIn 1.2s 0.5s both;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid rgba(192, 132, 252, 0.2);
    border-bottom: 1px solid rgba(192, 132, 252, 0.2);
  }

  .stat {
    padding: 3rem 4rem;
    border-right: 1px solid rgba(192, 132, 252, 0.2);
    text-align: center;
  }
  .stat:last-child { border-right: none; }

  .stat-num {
    font-size: clamp(3rem, 5vw, 5rem);
    font-weight: 300;
    color: var(--lavender);
    display: block;
    line-height: 1;
    font-style: italic;
  }

  .stat-label {
    font-family: 'Geist Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(245, 240, 255, 0.5);
    margin-top: 0.75rem;
    display: block;
  }

  .problem {
    padding: 10rem 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8rem;
    align-items: center;
    position: relative;
  }

  .problem::before {
    content: '10%';
    position: absolute;
    right: -1rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 20rem;
    font-weight: 300;
    color: rgba(107, 33, 168, 0.12);
    pointer-events: none;
    font-style: italic;
    line-height: 1;
  }

  .section-label {
    font-family: 'Geist Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--lavender);
    margin-bottom: 2rem;
  }

  .section-h2 {
    font-size: clamp(2.5rem, 4vw, 4.5rem);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin-bottom: 2rem;
  }
  .section-h2 em { font-style: italic; color: var(--lavender); }

  .section-body {
    font-size: 1.15rem;
    line-height: 1.8;
    color: rgba(245, 240, 255, 0.65);
  }

  .features {
    padding: 8rem 4rem;
    background: rgba(107, 33, 168, 0.08);
    border-top: 1px solid rgba(192, 132, 252, 0.15);
    border-bottom: 1px solid rgba(192, 132, 252, 0.15);
  }

  .features-header { text-align: center; margin-bottom: 6rem; }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
  }

  .feature-card {
    padding: 3.5rem 3rem;
    background: rgba(45, 10, 78, 0.6);
    border: 1px solid rgba(192, 132, 252, 0.12);
    position: relative;
    overflow: hidden;
    transition: background 0.3s;
  }
  .feature-card:hover { background: rgba(107, 33, 168, 0.2); }

  .feature-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px;
    height: 100%;
    background: var(--lavender);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.4s;
  }
  .feature-card:hover::before { transform: scaleY(1); }

  .feature-num {
    font-family: 'Geist Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    color: var(--lavender);
    margin-bottom: 2rem;
    opacity: 0.7;
  }

  .feature-title { font-size: 1.6rem; font-weight: 300; margin-bottom: 1rem; line-height: 1.2; }
  .feature-desc { font-size: 1rem; line-height: 1.7; color: rgba(245, 240, 255, 0.55); }

  .manifesto {
    padding: 12rem 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .manifesto::before {
    content: '';
    position: absolute;
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, rgba(107, 33, 168, 0.25) 0%, transparent 70%);
    border-radius: 50%;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    animation: pulse 5s ease-in-out infinite;
  }

  .manifesto-quote {
    font-size: clamp(2rem, 4vw, 4rem);
    font-weight: 300;
    font-style: italic;
    line-height: 1.3;
    max-width: 22ch;
    margin: 0 auto 3rem;
    position: relative;
    z-index: 2;
  }
  .manifesto-quote em { color: var(--lavender); font-style: normal; }

  .manifesto-attr {
    font-family: 'Geist Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(245, 240, 255, 0.4);
    position: relative;
    z-index: 2;
  }

  .product-detail {
    padding: 8rem 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .detail-img {
    width: 100%;
    filter: drop-shadow(0 20px 60px rgba(107, 33, 168, 0.5));
  }

  .specs-list { list-style: none; margin-top: 2.5rem; }

  .specs-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.1rem 0;
    border-bottom: 1px solid rgba(192, 132, 252, 0.15);
    font-size: 1rem;
    color: rgba(245, 240, 255, 0.7);
  }

  .specs-list li span:first-child {
    font-family: 'Geist Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--lavender);
  }

  .contact {
    padding: 10rem 4rem;
    background: linear-gradient(180deg, rgba(107, 33, 168, 0.15) 0%, rgba(45, 10, 78, 0.8) 100%);
    border-top: 1px solid rgba(192, 132, 252, 0.2);
  }

  .contact-inner { max-width: 680px; margin: 0 auto; }

  .contact-header { text-align: center; margin-bottom: 4rem; }

  .contact-h2 { font-size: clamp(2.5rem, 4vw, 4rem); font-weight: 300; margin-bottom: 1.2rem; }
  .contact-sub { font-size: 1.1rem; color: rgba(245, 240, 255, 0.55); line-height: 1.7; }

  .contact-form { display: flex; flex-direction: column; gap: 1.5rem; }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }

  .field { display: flex; flex-direction: column; gap: 0.5rem; }

  .field label {
    font-family: 'Geist Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--lavender);
  }

  .field input, .field textarea, .field select {
    background: rgba(107, 33, 168, 0.1);
    border: 1px solid rgba(192, 132, 252, 0.25);
    color: var(--pale);
    padding: 0.9rem 1.2rem;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }

  .field input:focus, .field textarea:focus, .field select:focus {
    border-color: var(--lavender);
    background: rgba(107, 33, 168, 0.18);
  }

  .field textarea { resize: vertical; min-height: 120px; }
  .field select option { background: var(--plum); color: var(--pale); }

  .submit-btn {
    background: var(--lavender);
    color: var(--plum);
    border: none;
    padding: 1.1rem 2.8rem;
    font-family: 'Geist Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    cursor: pointer;
    align-self: flex-start;
    transition: all 0.25s;
    margin-top: 0.5rem;
  }
  .submit-btn:hover { background: var(--pale); transform: translateY(-2px); box-shadow: 0 12px 40px rgba(192, 132, 252, 0.35); }

  footer {
    padding: 3rem 4rem;
    border-top: 1px solid rgba(192, 132, 252, 0.15);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-logo {
    font-family: 'Geist Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    color: var(--lavender);
    text-transform: uppercase;
  }

  .footer-note {
    font-family: 'Geist Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    color: rgba(245, 240, 255, 0.25);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes floatSpoon {
    0%, 100% { transform: translateY(0) rotate(-8deg); }
    50%       { transform: translateY(-20px) rotate(-6deg); }
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50%       { opacity: 1;   transform: scale(1.08); }
  }

  @media (max-width: 900px) {
    nav { padding: 1.2rem 2rem; }
    .hero { grid-template-columns: 1fr; min-height: auto; }
    .hero-left { padding: 9rem 2rem 4rem; }
    .hero-right { min-height: 50vh; }
    .stats { grid-template-columns: 1fr; }
    .stat { border-right: none; border-bottom: 1px solid rgba(192, 132, 252, 0.2); }
    .problem, .product-detail { grid-template-columns: 1fr; padding: 6rem 2rem; gap: 4rem; }
    .problem::before { display: none; }
    .features { padding: 6rem 2rem; }
    .features-grid { grid-template-columns: 1fr; }
    .manifesto { padding: 8rem 2rem; }
    .contact { padding: 6rem 2rem; }
    .form-row { grid-template-columns: 1fr; }
    footer { flex-direction: column; gap: 1rem; text-align: center; padding: 2rem; }
  }
</style>
</head>
<body>

<nav>
  <span class="nav-logo">Sinistral Studio</span>
  <button class="nav-cta" onclick="document.querySelector('.contact').scrollIntoView({behavior:'smooth'})">Contactar</button>
</nav>

<section class="hero">
  <div class="hero-left">
    <span class="hero-tag">Nuevo Producto — 2025</span>
    <h1 class="hero-h1">La cuchara<br>que el mundo<br><em>les debia.</em></h1>
    <p class="hero-sub">
      Durante siglos, el 10% de la humanidad ha tenido que adaptarse a un mundo disenado para la otra mano. Ese tiempo termino hoy.
    </p>
    <div class="hero-actions">
      <button class="btn-primary" onclick="document.querySelector('.contact').scrollIntoView({behavior:'smooth'})">Quiero la mia</button>
      <a href="#problem" class="btn-ghost">Saber mas</a>
    </div>
  </div>
  <div class="hero-right">
    <img class="hero-img" src="Gemini_Generated_Image_173nos173nos173n.png" alt="Cuchara Ergonomica para Zurdos">
  </div>
</section>

<div class="stats">
  <div class="stat">
    <span class="stat-num">10%</span>
    <span class="stat-label">De la poblacion mundial es zurda</span>
  </div>
  <div class="stat">
    <span class="stat-num">800M</span>
    <span class="stat-label">De personas que merecen comer mejor</span>
  </div>
  <div class="stat">
    <span class="stat-num">0</span>
    <span class="stat-label">Compromisos ergonomicos</span>
  </div>
</div>

<section class="problem" id="problem">
  <div>
    <p class="section-label">El problema</p>
    <h2 class="section-h2">Disenado para<br><em>la otra mano.</em></h2>
  </div>
  <div>
    <p class="section-body">
      Desde los cubiertos hasta los controles, el mundo industrial fue construido asumiendo que todos son diestros. Las cucharas convencionales tienen una curvatura y un angulo de agarre que genera tension muscular, fatiga y torpeza en personas zurdas.
      <br><br>
      Nuestra Cuchara Ergonomica para Zurdos nacio de un estudio de biomecanica de la muneca izquierda. Cada milimetro fue calculado para que el gesto de llevarte comida a la boca sea exactamente lo que siempre debio ser: natural.
    </p>
  </div>
</section>

<section class="features">
  <div class="features-header">
    <p class="section-label">Por que importa</p>
    <h2 class="section-h2" style="font-size:clamp(2rem,3.5vw,3.8rem); max-width:18ch; margin:0 auto;">
      Cada detalle fue <em>pensado para ti.</em>
    </h2>
  </div>
  <div class="features-grid">
    <div class="feature-card">
      <p class="feature-num">01</p>
      <h3 class="feature-title">Curvatura invertida</h3>
      <p class="feature-desc">El angulo de la cuchara sigue la trayectoria natural de la muneca izquierda, eliminando la torsion que genera fatiga en los tendones.</p>
    </div>
    <div class="feature-card">
      <p class="feature-num">02</p>
      <h3 class="feature-title">Agarre anatomico</h3>
      <p class="feature-desc">El grosor del mango fue modelado sobre mas de 200 moldes de manos zurdas. El resultado es un equilibrio entre control y confort.</p>
    </div>
    <div class="feature-card">
      <p class="feature-num">03</p>
      <h3 class="feature-title">Acero quirurgico</h3>
      <p class="feature-desc">Fabricada en acero inoxidable 18/10, libre de niquel y apta para lavavajillas. Una inversion que dura decadas.</p>
    </div>
    <div class="feature-card">
      <p class="feature-num">04</p>
      <h3 class="feature-title">Equilibrio perfecto</h3>
      <p class="feature-desc">El punto de gravedad fue desplazado tres milimetros hacia el lado izquierdo para que la cuchara repose en la mano sin esfuerzo.</p>
    </div>
    <div class="feature-card">
      <p class="feature-num">05</p>
      <h3 class="feature-title">Acabado satinado</h3>
      <p class="feature-desc">Una superficie mate que reduce los reflejos y da una textura ligeramente adherente, mejorando el control durante el uso.</p>
    </div>
    <div class="feature-card">
      <p class="feature-num">06</p>
      <h3 class="feature-title">Disenada con ciencia</h3>
      <p class="feature-desc">Desarrollada junto a especialistas en ergonomia y fisioterapia ocupacional para garantizar resultados clinicamente respaldados.</p>
    </div>
  </div>
</section>

<section class="manifesto">
  <p class="manifesto-quote">
    "El buen diseno no elige quien lo merece. <em>Nosotros tampoco.</em>"
  </p>
  <span class="manifesto-attr">Sinistral Studio — Manifiesto de Producto</span>
</section>

<section class="product-detail">
  <div>
    <img class="detail-img" src="Gemini_Generated_Image_173nos173nos173n.png" alt="Vista detalle cuchara">
  </div>
  <div>
    <p class="section-label">Especificaciones</p>
    <h2 class="section-h2" style="font-size: clamp(2rem, 3vw, 3.2rem); margin-bottom:0.5rem;">
      Precision en<br><em>cada gramo.</em>
    </h2>
    <ul class="specs-list">
      <li><span>Material</span> <span>Acero inoxidable 18/10</span></li>
      <li><span>Longitud</span> <span>19.5 cm</span></li>
      <li><span>Peso</span> <span>48 g — equilibrado</span></li>
      <li><span>Acabado</span> <span>Satinado mate premium</span></li>
      <li><span>Apta para</span> <span>Lavavajillas, uso diario</span></li>
      <li><span>Certificacion</span> <span>Libre de niquel, BPA-free</span></li>
      <li><span>Garantia</span> <span>De por vida</span></li>
    </ul>
  </div>
</section>

<section class="contact">
  <div class="contact-inner">
    <div class="contact-header">
      <p class="section-label" style="text-align:center;">Contacto</p>
      <h2 class="contact-h2">Reserva la tuya<br>o escribenos.</h2>
      <p class="contact-sub">
        Lanzamiento limitado. Cada unidad se produce bajo pedido para garantizar la calidad que tu mano izquierda merece.
      </p>
    </div>
    <div class="contact-form">
      <div class="form-row">
        <div class="field">
          <label for="nombre">Nombre</label>
          <input type="text" id="nombre" placeholder="Tu nombre completo">
        </div>
        <div class="field">
          <label for="email">Correo electronico</label>
          <input type="email" id="email" placeholder="tucorreo@ejemplo.com">
        </div>
      </div>
      <div class="field">
        <label for="pais">Pais</label>
        <select id="pais">
          <option value="">Selecciona tu pais</option>
          <option>Guatemala</option>
          <option>Mexico</option>
          <option>Colombia</option>
          <option>Argentina</option>
          <option>Espana</option>
          <option>Estados Unidos</option>
          <option>Otro</option>
        </select>
      </div>
      <div class="field">
        <label for="interes">Motivo</label>
        <select id="interes">
          <option value="">Que te trae por aqui</option>
          <option>Quiero comprar una unidad</option>
          <option>Quiero comprar un set de regalo</option>
          <option>Soy distribuidor mayorista</option>
          <option>Tengo una consulta</option>
        </select>
      </div>
      <div class="field">
        <label for="mensaje">Mensaje</label>
        <textarea id="mensaje" placeholder="Cuentanos lo que necesitas..."></textarea>
      </div>
      <button class="submit-btn" id="submitBtn">Enviar mensaje</button>
    </div>
  </div>
</section>

<footer>
  <span class="footer-logo">Sinistral Studio</span>
  <span class="footer-note">Cuchara Ergonomica para Zurdos — Todos los derechos reservados 2025</span>
</footer>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.style.opacity = '1';
        entry.target.style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.stat, .feature-card, .section-h2, .section-body, .specs-list').forEach(el => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(24px)';
    el.style.transition = 'opacity 0.7s ease, transform 0.7s ease';
    observer.observe(el);
  });

  document.getElementById('submitBtn').addEventListener('click', () => {
    const btn = document.getElementById('submitBtn');
    btn.textContent = 'Enviado — Gracias';
    btn.style.background = '#22c55e';
    btn.style.color = '#fff';
    setTimeout(() => {
      btn.textContent = 'Enviar mensaje';
      btn.style.background = '';
      btn.style.color = '';
    }, 3000);
  });
</script>
</body>
</html>
